# ==========================================
# ENVIRONMENT VARIABLES - Copy to .env
# ==========================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Note: 
# - SUPABASE_URL: Lấy từ Supabase Dashboard > Settings > API > URL
# - SUPABASE_KEY: Dùng service_role key (secret) cho backend, anon key cho frontend
# - Không commit file .env này lên GitHub!
